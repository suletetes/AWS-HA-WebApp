<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="refresh" content="<%= Math.floor(refreshInterval / 1000) %>">
  <title>CloudPulse - Infrastructure Health Dashboard</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, sans-serif;
      background-color: #1a1a2e;
      color: #e0e0e0;
      line-height: 1.6;
      padding: 20px;
    }

    h1 {
      text-align: center;
      margin-bottom: 30px;
      font-size: 1.8rem;
      color: #ffffff;
    }

    h1 span {
      color: #00d4aa;
    }

    h2 {
      font-size: 1.2rem;
      margin-bottom: 15px;
      color: #ffffff;
    }

    .dashboard {
      max-width: 1200px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
    }

    .card {
      background-color: #16213e;
      border-radius: 12px;
      padding: 24px;
      box-shadow: 0 4px 15px rgba(0, 0, 0, 0.3);
    }

    .card.full-width {
      grid-column: 1 / -1;
    }

    .error-box {
      background-color: rgba(255, 71, 87, 0.15);
      border: 1px solid #ff4757;
      border-radius: 8px;
      padding: 12px 16px;
      color: #ff4757;
      font-size: 0.9rem;
    }

    .capacity-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 12px;
    }

    .capacity-item {
      background-color: #1a1a2e;
      border-radius: 8px;
      padding: 16px;
      text-align: center;
    }

    .capacity-item .label {
      font-size: 0.8rem;
      text-transform: uppercase;
      color: #888;
      margin-bottom: 4px;
    }

    .capacity-item .value {
      font-size: 1.8rem;
      font-weight: bold;
      color: #00d4aa;
    }

    table {
      width: 100%;
      border-collapse: collapse;
    }

    th, td {
      padding: 10px 12px;
      text-align: left;
      border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }

    th {
      font-size: 0.8rem;
      text-transform: uppercase;
      color: #888;
      font-weight: 600;
    }

    td {
      font-size: 0.9rem;
    }

    .status-healthy {
      color: #00d4aa;
      font-weight: 600;
    }

    .status-unhealthy {
      color: #ff4757;
      font-weight: 600;
    }

    .instance-info {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap: 16px;
    }

    .instance-info .info-item {
      background-color: #1a1a2e;
      border-radius: 8px;
      padding: 16px;
    }

    .instance-info .info-item .label {
      font-size: 0.8rem;
      text-transform: uppercase;
      color: #888;
      margin-bottom: 4px;
    }

    .instance-info .info-item .value {
      font-size: 1.2rem;
      font-weight: bold;
      color: #ffffff;
    }

    .progress-bar {
      width: 100%;
      height: 8px;
      background-color: #1a1a2e;
      border-radius: 4px;
      overflow: hidden;
      margin-top: 8px;
    }

    .progress-bar .fill {
      height: 100%;
      border-radius: 4px;
      transition: width 0.3s ease;
    }

    .progress-bar .fill.low {
      background-color: #00d4aa;
    }

    .progress-bar .fill.medium {
      background-color: #ffa502;
    }

    .progress-bar .fill.high {
      background-color: #ff4757;
    }

    .empty-state {
      color: #888;
      font-style: italic;
      padding: 12px 0;
    }

    footer {
      text-align: center;
      margin-top: 30px;
      color: #666;
      font-size: 0.85rem;
    }

    @media (max-width: 768px) {
      .dashboard {
        grid-template-columns: 1fr;
      }

      .capacity-grid {
        grid-template-columns: repeat(2, 1fr);
      }

      .instance-info {
        grid-template-columns: 1fr;
      }
    }
  </style>
</head>
<body>
  <h1><span>Cloud</span>Pulse</h1>

  <div class="dashboard">
    <!-- Current Instance Section -->
    <div class="card">
      <h2>Current Instance</h2>
      <% if (errors.currentInstance) { %>
        <div class="error-box"><%= errors.currentInstance %></div>
      <% } else if (currentInstance) { %>
        <div class="instance-info">
          <div class="info-item">
            <div class="label">Instance ID</div>
            <div class="value"><%= currentInstance.instanceId %></div>
          </div>
          <div class="info-item">
            <div class="label">Uptime</div>
            <div class="value"><%= Math.floor(currentInstance.uptime / 3600) %>:<%= String(Math.floor((currentInstance.uptime % 3600) / 60)).padStart(2, '0') %>:<%= String(Math.floor(currentInstance.uptime % 60)).padStart(2, '0') %></div>
          </div>
          <div class="info-item">
            <div class="label">CPU Usage</div>
            <div class="value"><%= currentInstance.cpuUsage.toFixed(1) %>%</div>
            <div class="progress-bar">
              <div class="fill <%= currentInstance.cpuUsage < 50 ? 'low' : currentInstance.cpuUsage < 80 ? 'medium' : 'high' %>" style="width: <%= Math.min(currentInstance.cpuUsage, 100) %>%"></div>
            </div>
          </div>
        </div>
      <% } else { %>
        <p class="empty-state">No instance data available.</p>
      <% } %>
    </div>

    <!-- ASG Capacity Section -->
    <div class="card">
      <h2>ASG Capacity</h2>
      <% if (errors.capacity) { %>
        <div class="error-box"><%= errors.capacity %></div>
      <% } else if (capacity) { %>
        <div class="capacity-grid">
          <div class="capacity-item">
            <div class="label">Min</div>
            <div class="value"><%= capacity.min %></div>
          </div>
          <div class="capacity-item">
            <div class="label">Max</div>
            <div class="value"><%= capacity.max %></div>
          </div>
          <div class="capacity-item">
            <div class="label">Desired</div>
            <div class="value"><%= capacity.desired %></div>
          </div>
          <div class="capacity-item">
            <div class="label">Actual</div>
            <div class="value"><%= capacity.actual %></div>
          </div>
        </div>
      <% } else { %>
        <p class="empty-state">No capacity data available.</p>
      <% } %>
    </div>

    <!-- Instance Health Section -->
    <div class="card full-width">
      <h2>Instance Health</h2>
      <% if (errors.instances) { %>
        <div class="error-box"><%= errors.instances %></div>
      <% } else if (instances && instances.length > 0) { %>
        <table>
          <thead>
            <tr>
              <th>Instance ID</th>
              <th>State</th>
              <th>Health Status</th>
              <th>Availability Zone</th>
            </tr>
          </thead>
          <tbody>
            <% instances.forEach(function(instance) { %>
              <tr>
                <td><%= instance.instanceId %></td>
                <td><%= instance.state %></td>
                <td class="<%= instance.healthStatus.toLowerCase() === 'healthy' ? 'status-healthy' : 'status-unhealthy' %>"><%= instance.healthStatus %></td>
                <td><%= instance.availabilityZone %></td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      <% } else { %>
        <p class="empty-state">No instances found.</p>
      <% } %>
    </div>

    <!-- Recent Scaling Events Section -->
    <div class="card full-width">
      <h2>Recent Scaling Events</h2>
      <% if (errors.activities) { %>
        <div class="error-box"><%= errors.activities %></div>
      <% } else if (scalingActivities && scalingActivities.length > 0) { %>
        <table>
          <thead>
            <tr>
              <th>Timestamp</th>
              <th>Description</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody>
            <% scalingActivities.slice(0, 10).forEach(function(activity) { %>
              <tr>
                <td><%= activity.timestamp %></td>
                <td><%= activity.description %></td>
                <td><%= activity.statusCode %></td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      <% } else { %>
        <p class="empty-state">No recent scaling events.</p>
      <% } %>
    </div>
  </div>

  <footer>
    CloudPulse v1.0 | Auto-refreshes every <%= Math.floor(refreshInterval / 1000) %>s
  </footer>
</body>
</html>
