# CloudPulse Dashboard - Environment Variables
# Copy this file to .env and fill in the values

# Server port (default: 3000)
PORT=3000

# AWS region for SDK clients (default: us-east-1)
AWS_REGION=us-east-1

# Auto Scaling Group name (REQUIRED)
ASG_NAME=cloudpulse-asg

# CloudWatch metrics namespace (default: CloudPulse)
METRICS_NAMESPACE=CloudPulse

# Metrics publishing interval in milliseconds (default: 60000)
METRICS_INTERVAL_MS=60000

# Dashboard auto-refresh interval in milliseconds (default: 30000)
DASHBOARD_REFRESH_MS=30000

# Log file path (default: /var/log/cloudpulse/app.log)
LOG_FILE_PATH=/var/log/cloudpulse/app.log

# Maximum log file size before rotation (default: 50m)
LOG_MAX_SIZE=50m

# Maximum number of rotated log files to retain (default: 5)
LOG_MAX_FILES=5

# Health check timeout in milliseconds (default: 5000)
HEALTH_CHECK_TIMEOUT_MS=5000

# Maximum retry attempts for AWS API calls (default: 3)
RETRY_MAX_ATTEMPTS=3

# Base delay for exponential backoff in milliseconds (default: 1000)
RETRY_BASE_DELAY_MS=1000
